# Reference only — the app does not load this file. Copy keys into a real `.env` next to package.json.
# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Prisma: `url` is what the app uses; `directUrl` is for migrations (schema.prisma)
# Local dev: both can be the same direct connection (port 5432).
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Vercel / serverless: DATABASE_URL MUST use Supabase "Transaction pooler" (port 6543 + ?pgbouncer=true&connection_limit=1).
# Dashboard → Settings → Database → Connection string → Transaction pooler.
# Using db.*.supabase.co:5432 on Vercel usually fails with "Can't reach database server".
# Keep DIRECT_URL as the direct :5432 string for `npx prisma migrate deploy` run from your machine/CI.

# Server Configuration
PORT=3001
NODE_ENV=development

# Admin (seed + OTP reset)
# Set these in your real `.env` / Vercel env vars (do not commit secrets)
ADMIN_SEED_EMAIL=guruuakanksha2019@gmail.com
ADMIN_SEED_PASSWORD=PASTE_ADMIN_PASSWORD_HERE
ADMIN_OTP_TTL_MINUTES=10
ADMIN_DEFAULT_PASSWORD=change-me

# Storage Buckets
CAMPAIGNS_BUCKET=campaigns-images
EVENTS_BUCKET=events-images
TEAM_BUCKET=team-photos
PARTNERS_BUCKET=partners-logos
HERO_SLIDES_BUCKET=hero-slides
DONATIONS_BUCKET=receipts

# Donate page — payment instructions (served via GET /api/public/donation-payment-info)
FRONTEND_URL=http://localhost:3000
DONATION_UPI_ID=yourname@upi
# Full URL to QR image, or path on the frontend (file under frontend/public/images/)
DONATION_UPI_QR_URL=/images/QRCODE.jpeg
DONATION_BANK_NAME=Your Bank Name
DONATION_BANK_ACCOUNT=000000000000
DONATION_BANK_IFSC=XXXX0000000